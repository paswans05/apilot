    "vite-plugin-electron-renderer": "^0.14.7",
    "vite-plugin-svgr": "5.2.0",
    "vite-tsconfig-paths": "6.1.1"
  },
  "scripts": {
    "start": "npm run dev",
    "dev": "vite",
    "build": "set NODE_OPTIONS=--max-old-space-size=4096 && tsc && vite build",
    "electron:dev": "vite",
    "electron:build": "set NODE_OPTIONS=--max-old-space-size=4096 && vite build && electron-builder",
    "lint": "eslint ./src --config ./eslint.config.mjs",
    "lint:fix": "eslint --fix ./src --config ./eslint.config.mjs",
    "preview": "vite preview",
    "build-docs": "npx tsx  \"./src/app/(public)/documentation/material-ui-components/utils/build.ts\"",
    "postinstall": "node src/utils/node-scripts/fuse-react-message.js",
    "poststart": "node src/utils/node-scripts/fuse-react-message.js",
    "audit": "npm audit --production"
  },
  "engines": {
    "node": ">=22.12.0",
    "npm": ">=10.9.0"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 3 safari version"
    ]
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  },
  "build": {
    "appId": "com.apilot.app",
    "productName": "aPilot",
    "copyright": "Copyright © 2026 aPilot",
    "icon": "public/assets/images/logo/icon.png",
    "npmRebuild": false,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "build/**/*",
      "package.json",
      "!node_modules/**/*"
    ],
    "win": {
      "icon": "public/assets/images/logo/icon.png",
      "target": [
        "nsis"
      ]
    },
    "mac": {
      "icon": "public/assets/images/logo/icon.png",
      "category": "public.app-category.productivity"
    },
    "linux": {
      "icon": "public/assets/images/logo/icon.png",
      "category": "Utility"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "public/assets/images/logo/icon.png",
      "uninstallerIcon": "public/assets/images/logo/icon.png",
      "installerHeaderIcon": "public/assets/images/logo/icon.png"
    }
  }
}
